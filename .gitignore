# Environment & local secrets (never commit)
.env
.env.*

# Release signing material (local only)
*.pem
*.p12
*.pfx
signing/

# Sponsor wallet (real TRC20 address — use scripts/sponsor.json.example as template)
scripts/sponsor.json

# Test / coverage / lint cache
coverage/
playwright-report/
test-results/
scripts/test/test-results/
scripts/test/playwright-report/
node_modules/playwright-core/.local-browsers/
.eslintcache
*.tsbuildinfo

# Logs
logs
*.log
.debug/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependencies & build output
node_modules/
dist/
dist-ssr/
src-tauri/target/
*.local

# Python virtualenvs (local)
.venv/
.venv-*/

# Editor / IDE (local workspace)
.vscode/*
!.vscode/extensions.json
.idea/

# macOS metadata (do not commit — may leak folder layout, previews, paths)
.DS_Store
**/.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows metadata (thumbnail cache — may leak folder previews)
Thumbs.db
**/Thumbs.db

*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- Docs: local / maintainer only (app + CI do not need these) ---
docs/compatibility/
docs/qa/
docs/adr/

# --- Scripts: local only (published list → scripts/README.md § Published) ---
scripts/maintenance/
scripts/test/
scripts/test/run-*.mjs
scripts/test/mode-switch-regression-baseline.json
scripts/test/mode-switch-regression-history.json
scripts/test/test-results/
scripts/test/playwright-report/
scripts/locale/apply_*.py
scripts/locale/apply_*.mjs
scripts/locale_corpus/data/
scripts/**/__pycache__/
scripts/**/*.pyc

tmp/
