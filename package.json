{
  "name": "crossplatnote",
  "private": true,
  "version": "0.5.0",
  "description": "Lunote — local-first cross-platform Markdown notes & PKM app with wiki links, backlinks, knowledge graph, and offline storage.",
  "keywords": [
    "markdown",
    "markdown-editor",
    "notes",
    "note-taking",
    "pkm",
    "personal-knowledge-management",
    "knowledge-management",
    "knowledge-graph",
    "wiki-links",
    "backlinks",
    "bidirectional-links",
    "local-first",
    "offline-first",
    "offline-notes",
    "open-source",
    "cross-platform",
    "desktop-app",
    "tauri",
    "obsidian-alternative",
    "logseq-alternative",
    "zettelkasten",
    "second-brain",
    "markdown-to-pdf",
    "productivity"
  ],
  "type": "module",
  "scripts": {
    "predev": "node scripts/build/sync-version.mjs && node scripts/build/generate_mac_menu_boot.mjs",
    "dev": "node node_modules/vite/bin/vite.js",
