    "test:export-theme-css-filter": "node scripts/test/run-export-theme-css-filter-tests.mjs",
    "test:history-conflict-overlay": "node scripts/test/run-history-conflict-overlay-tests.mjs",
    "test:history-diff": "node scripts/test/run-history-diff-tests.mjs",
    "test:history-restore": "node scripts/test/run-history-restore-tests.mjs",
    "test:overlay-ui": "node scripts/test/run-overlay-ui-qa.mjs",
    "test:mode-switch-e2e": "node scripts/test/run-mode-switch-e2e.mjs",
    "test:e2e": "PLAYWRIGHT_BROWSERS_PATH=0 playwright test",
