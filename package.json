    "validate:mac-menu-boot": "node scripts/validate/validate_mac_menu_boot.mjs",
    "verify:locale-pipeline": "node scripts/validate/verify_locale_pipeline.mjs",
    "verify:ci": "node scripts/validate/verify_github_ci.mjs --job build",
    "verify:ci:checks": "node scripts/validate/verify_github_ci.mjs --job checks",
    "verify:ci:all": "node scripts/validate/verify_github_ci.mjs --job all",
    "validate:app-icons": "python3 scripts/validate/validate_app_icons.py",
    "validate:release-config": "node scripts/release/validate_release_config.mjs",
