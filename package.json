    "assets:readme-demo-gif:video:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/maintenance/convert-readme-demo-video.ps1 -Input",
    "patch:readme-preview-demo": "python3 scripts/maintenance/patch_readme_preview_demo.py",
    "sync:readme-locales": "python3 scripts/maintenance/sync_readme_locale_shell.py && python3 scripts/maintenance/apply_readme_core_sections.py && python3 scripts/maintenance/apply_readme_marketing_sections.py && python3 scripts/maintenance/patch_readme_tail_sections.py && python3 scripts/maintenance/gen_zh_tw_readme_from_zh_cn.py && python3 scripts/maintenance/apply_readme_zh_tw_guide_links.py",
    "release:publish": "node scripts/release/release-publish.mjs"
