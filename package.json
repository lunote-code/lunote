    "test:knowledge": "PLAYWRIGHT_BROWSERS_PATH=0 playwright test scripts/test/knowledge",
    "test:preferences": "PLAYWRIGHT_BROWSERS_PATH=0 playwright test scripts/test/preferences",
    "test:export": "PLAYWRIGHT_BROWSERS_PATH=0 playwright test scripts/test/export",
    "test:snapshot": "PLAYWRIGHT_BROWSERS_PATH=0 playwright test scripts/test/snapshot",
    "test:mermaid": "PLAYWRIGHT_BROWSERS_PATH=0 playwright test scripts/test/mermaid",
    "test:startup": "PLAYWRIGHT_BROWSERS_PATH=0 playwright test scripts/test/startup",
    "test:mode-switch": "PLAYWRIGHT_BROWSERS_PATH=0 playwright test scripts/test/mode-switch",
    "test:ui": "PLAYWRIGHT_BROWSERS_PATH=0 playwright test scripts/test/ui",
    "test:menu": "PLAYWRIGHT_BROWSERS_PATH=0 playwright test scripts/test/menu",
