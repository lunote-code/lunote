    "tauri:build:win": "node scripts/release/tauri-build-windows.mjs",
    "version:sync": "node scripts/build/sync-version.mjs",
    "version:check": "node scripts/build/sync-version.mjs --check",
    "version": "node scripts/build/sync-version.mjs",
    "sync:sponsor": "python3 scripts/maintenance/sync_sponsor_to_readmes.py",
