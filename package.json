{
  "name": "crossplatnote",
  "private": true,
  "version": "0.4.0",
  "description": "Lunote — local-first cross-platform Markdown notes & PKM app with wiki links, backlinks, knowledge graph, and offline storage.",
  "keywords": [
    "markdown",
    "markdown-editor",
    "notes",
    "note-taking",
    "pkm",
    "personal-knowledge-management",
    "knowledge-management",
    "knowledge-graph",
    "wiki-links",
    "backlinks",
    "bidirectional-links",
    "local-first",
    "offline-first",
    "offline-notes",
    "open-source",
    "cross-platform",
    "desktop-app",
    "tauri",
    "obsidian-alternative",
    "logseq-alternative",
    "zettelkasten",
    "second-brain",
    "markdown-to-pdf",
    "productivity"
  ],
  "type": "module",
  "scripts": {
    "predev": "node scripts/sync-version.mjs",
    "dev": "node node_modules/vite/bin/vite.js",
    "prebuild": "node scripts/sync-version.mjs",
    "build": "node node_modules/typescript/bin/tsc -b && node node_modules/vite/bin/vite.js build",
    "lint": "node node_modules/eslint/bin/eslint.js .",
    "test:mode-switch-contract": "node scripts/run-mode-switch-contract-tests.mjs",
    "regression:mode-switch": "node scripts/run-mode-switch-regression.mjs --assert --baseline scripts/mode-switch-regression-baseline.json --history scripts/mode-switch-regression-history.json",
    "regression:mode-switch:baseline:update": "node scripts/run-mode-switch-regression.mjs --baseline scripts/mode-switch-regression-baseline.json --write-baseline",
    "regression:mode-switch:history:update": "node scripts/run-mode-switch-regression.mjs --history scripts/mode-switch-regression-history.json --append-history",
    "regression:mode-switch:history:checkpoint": "node scripts/run-mode-switch-regression.mjs --history scripts/mode-switch-regression-history.json --append-history --history-stage checkpoint",
    "regression:mode-switch:history:p2:ir-scope": "node scripts/run-mode-switch-regression.mjs --history scripts/mode-switch-regression-history.json --append-history --history-stage p2 --history-note ir-scope",
    "regression:mode-switch:history:p2:metrics": "node scripts/run-mode-switch-regression.mjs --history scripts/mode-switch-regression-history.json --append-history --history-stage p2 --history-note metrics",
    "regression:mode-switch:history:p2:decision-gate": "node scripts/run-mode-switch-regression.mjs --history scripts/mode-switch-regression-history.json --append-history --history-stage p2 --history-note decision-gate",
    "verify:mode-switch": "npm run test:mode-switch-contract && npm run regression:mode-switch",
    "verify:mode-switch:full": "npm run verify:mode-switch && npm run build",
    "prepreview": "node scripts/sync-version.mjs",
    "preview": "node node_modules/vite/bin/vite.js preview",
    "export:pdf": "node scripts/render-html-pdf.mjs",
    "pretauri:dev": "node scripts/sync-version.mjs",
    "tauri:dev": "node node_modules/@tauri-apps/cli/tauri.js dev",
    "pretauri:build": "node scripts/sync-version.mjs",
    "tauri:build": "node node_modules/@tauri-apps/cli/tauri.js build",
    "pretauri:bundle": "node scripts/sync-version.mjs",
    "tauri:bundle": "node node_modules/@tauri-apps/cli/tauri.js build",
    "release:prepare-signing": "node scripts/prepare-signing.mjs",
    "release:sign-deb": "node scripts/sign-deb.mjs",
    "pretauri:bundle:dmg": "node scripts/sync-version.mjs",
    "tauri:bundle:dmg": "node scripts/prepare-signing.mjs && node node_modules/@tauri-apps/cli/tauri.js build --bundles dmg",
    "pretauri:bundle:msi": "node scripts/sync-version.mjs",
    "tauri:bundle:msi": "node scripts/prepare-signing.mjs && node node_modules/@tauri-apps/cli/tauri.js build --bundles msi",
    "pretauri:bundle:deb": "node scripts/sync-version.mjs",
    "tauri:bundle:deb": "node scripts/prepare-signing.mjs && node node_modules/@tauri-apps/cli/tauri.js build --bundles deb && node scripts/sign-deb.mjs",
    "pretauri:bundle:rpm": "node scripts/sync-version.mjs",
    "tauri:bundle:rpm": "node scripts/prepare-signing.mjs && node node_modules/@tauri-apps/cli/tauri.js build --bundles rpm",
    "pretauri:build:win": "node scripts/sync-version.mjs",
    "tauri:build:win": "node scripts/tauri-build-windows.mjs",
    "version:sync": "node scripts/sync-version.mjs",
    "version:check": "node scripts/sync-version.mjs --check",
    "version": "node scripts/sync-version.mjs",
    "sync:sponsor": "python3 scripts/maintenance/sync_sponsor_to_readmes.py",
    "sync:sponsor:check": "python3 scripts/maintenance/sync_sponsor_to_readmes.py --check",
    "validate:readme-locales": "python3 scripts/maintenance/validate_readme_locales.py",
    "assets:readme-demo-gif": "node scripts/maintenance/build-readme-demo-gif.mjs",
    "assets:readme-demo-gif:video": "bash scripts/maintenance/convert-readme-demo-video.sh",
    "assets:readme-demo-gif:video:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/maintenance/convert-readme-demo-video.ps1 -Input",
    "patch:readme-preview-demo": "python3 scripts/maintenance/patch_readme_preview_demo.py",
    "sync:readme-locales": "python3 scripts/maintenance/sync_readme_locale_shell.py",
    "release:publish": "node scripts/release-publish.mjs"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/search": "^6.7.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.42.1",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tiptap/core": "^3.23.1",
    "@tiptap/extension-code-block-lowlight": "^3.23.1",
    "@tiptap/extension-heading": "^3.23.1",
    "@tiptap/extension-image": "^3.23.1",
    "@tiptap/extension-link": "^3.23.1",
    "@tiptap/extension-mathematics": "^3.23.1",
    "@tiptap/extension-placeholder": "^3.23.1",
    "@tiptap/extension-subscript": "^3.23.1",
    "@tiptap/extension-superscript": "^3.23.1",
    "@tiptap/extension-table": "^3.23.1",
    "@tiptap/extension-table-cell": "^3.23.1",
    "@tiptap/extension-table-header": "^3.23.1",
    "@tiptap/extension-table-row": "^3.23.1",
    "@tiptap/extension-task-item": "^3.23.1",
    "@tiptap/extension-task-list": "^3.23.1",
    "@tiptap/extension-underline": "^3.23.1",
    "@tiptap/pm": "^3.23.1",
    "@tiptap/react": "^3.23.1",
    "@tiptap/starter-kit": "^3.23.1",
    "@types/hast": "^3.0.4",
    "@uiw/react-codemirror": "^4.25.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dagre-d3-es": "7.0.14",
    "docx": "^9.6.1",
    "dompurify": "^3.4.2",
    "github-markdown-css": "^5.9.0",
    "github-slugger": "^2.0.0",
    "highlight.js": "^11.11.1",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "katex": "^0.16.45",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.14.0",
    "markdown-it": "^14.1.1",
    "markdown-it-container": "^4.0.0",
    "markdown-it-deflist": "^3.0.0",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-sub": "^2.0.0",
    "markdown-it-sup": "^2.0.0",
    "markdown-it-texmath": "^1.0.0",
    "marked": "^18.0.3",
    "marked-highlight": "^2.2.4",
    "mermaid": "^11.15.0",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-history": "^1.5.0",
    "prosemirror-inputrules": "^1.5.1",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-markdown": "^1.13.4",
    "prosemirror-model": "^1.25.4",
    "prosemirror-schema-basic": "^1.2.4",
    "prosemirror-schema-list": "^1.5.1",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.41.8",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-breaks": "^4.0.0",
    "remark-definition-list": "^2.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gemoji": "^8.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-supersub": "^1.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.11.1",
    "@types/dompurify": "^3.0.5",
    "@types/marked": "^5.0.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gifenc": "^1.0.3",
    "globals": "^17.5.0",
    "pngjs": "^7.0.0",
    "puppeteer-core": "^24.43.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
