{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node", "@playwright/test"],
    "isolatedModules": true,
    "verbatimModuleSyntax": true
  },
  "include": ["test/**/*.ts"]
}
