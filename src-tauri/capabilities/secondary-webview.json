{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "secondary-webview",
  "description": "Runtime-created webview windows (export preview, help, etc.)",
  "windows": ["export-preview", "help", "secondary-*"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:webview:allow-print",
    "dialog:default"
  ]
}
